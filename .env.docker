APP_NAME=Brewlang
APP_ENV=local
APP_KEY=            # will be generated by entrypoint.sh
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=brewlang
DB_USERNAME=brewlang
DB_PASSWORD=secret

CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM_ADDRESS=noreply@brewlang.test
MAIL_FROM_NAME="Brewlang Coffee"

FILESYSTEM_DISK=local
